&control
    calculation = 'bands'
    prefix = 'Al'
    pseudo_dir = '../pseudo/'
    outdir = '../tmp_Al/'
    verbosity = 'high'
/
&system
    ibrav = 0, nat = 1, ntyp = 1,
    nbnd = 8,
    ecutwfc = 50.0,
    occupations = 'smearing', smearing = 'mp', degauss = 0.02
/
&electrons
    conv_thr = 1.0d-8
/
