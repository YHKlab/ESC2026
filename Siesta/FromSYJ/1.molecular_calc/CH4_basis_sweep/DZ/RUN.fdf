SystemName      CH4 molecule (SIESTA 5.4.2 tutorial)
SystemLabel     CH4

%include STRUCT.fdf
%include BASIS.fdf
%include KPT.fdf

# Exchange-correlation (must match Pseudo-Dojo PSML generator)
XC.functional   GGA
XC.authors      PBE

# SCF
MeshCutoff       200.0 Ry
DM.Tolerance     1.d-4
DM.MixingWeight  0.1
DM.NumberPulay   4
MaxSCFIterations 200

# Structure optimization (CG)
MD.TypeOfRun     CG
MD.Steps 300
MD.MaxForceTol   0.01 eV/Ang
MD.MaxCGDispl    0.20 Bohr

# Output
WriteCoorXmol    T
WriteForces      T
WriteMDhistory   T
SaveRho          T
WriteEigenvalues T
