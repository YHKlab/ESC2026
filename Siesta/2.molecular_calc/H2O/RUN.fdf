SystemName      H2O molecule (SIESTA 5.4.2 tutorial)
SystemLabel     H2O

%include STRUCT.fdf
%include BASIS.fdf
%include KPT.fdf

# Exchange-correlation (Pseudo-Dojo PBE)
XC.functional   GGA
XC.authors      PBE

# SCF
MeshCutoff       200.0 Ry
DM.Tolerance     1.d-4
DM.MixingWeight  0.1
DM.NumberPulay   4
MaxSCFIterations 200

# Structure optimization (CG)
MD.TypeOfRun     CG
MD.Steps 300
MD.MaxForceTol   0.01 eV/Ang
MD.MaxCGDispl    0.20 Bohr

# 전자 밀도 시각화에 필요한 출력
SaveRho          T
SaveDeltaRho     T
WriteHirshfeldPop T

# 기타 출력
WriteCoorXmol    T
WriteForces      T
WriteMDhistory   T
WriteEigenvalues T
