SystemName      NH3 molecule (SIESTA 5.4.2 tutorial)
SystemLabel     NH3

%include STRUCT.fdf
%include BASIS.fdf
%include KPT.fdf

# Exchange-correlation
XC.functional   GGA
XC.authors      PBE

# SCF
MeshCutoff       200.0 Ry
DM.Tolerance     1.d-4
DM.MixingWeight  0.1
DM.NumberPulay   4
MaxSCFIterations 200

# Structure optimization (CG) — 학생이 직접 수정해 보자
MD.TypeOfRun     CG
MD.Steps 300
MD.MaxForceTol   0.01 eV/Ang
MD.MaxCGDispl    0.20 Bohr

# 출력 옵션 (전자 밀도까지 보고 싶다면 H2O 예시처럼 SaveRho/SaveDeltaRho 를 켜 보자)
WriteCoorXmol    T
WriteForces      T
WriteMDhistory   T
# SaveRho          T
# SaveDeltaRho     T
# WriteHirshfeldPop T
